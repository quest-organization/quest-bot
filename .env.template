DISCORD_TOKEN=your bot's token
APPLICATION_ID=your bot's application id
DATABASE_URL=postgresql://databaseurl

DEV=true/false (this env var is optional)
DEVIDS=list of userids that can run commands when in dev mode (this env var is optional)
KUMA_PUSH_URL=heartbeat url for uptime kuma (this env var is optional)
LIMITS=true/false (this env var is optional, it will enable limits for commands such as reminders and autoroles if true)